// ============ EXPORT PDF ============
async function exportPDF() {
  closeDropdowns();
  const trip = getCurrentTrip();
  if (!trip) { showToast('請先選擇旅程', 'error'); return; }
  showToast('正在產生 PDF...', 'info');

  const container = document.getElementById('exportRender');
  container.innerHTML = buildExportHTML(trip);
  container.style.width = '800px';
  container.style.left = '0';

  try {
    await new Promise(r => setTimeout(r, 300));
    const canvas = await html2canvas(container, { scale: 2, useCORS: true, backgroundColor: '#ffffff' });
    const imgData = canvas.toDataURL('image/png');
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF('p', 'mm', 'a4');
    const pdfW = pdf.internal.pageSize.getWidth();
    const pdfH = (canvas.height * pdfW) / canvas.width;

    let heightLeft = pdfH;
    let position = 0;
    pdf.addImage(imgData, 'PNG', 0, position, pdfW, pdfH);
    heightLeft -= pdf.internal.pageSize.getHeight();

    while (heightLeft > 0) {
      position -= pdf.internal.pageSize.getHeight();
      pdf.addPage();
      pdf.addImage(imgData, 'PNG', 0, position, pdfW, pdfH);
      heightLeft -= pdf.internal.pageSize.getHeight();
    }

    pdf.save(`${trip.title || 'trip'}.pdf`);
    showToast('已匯出 PDF', 'success');
  } catch(e) {
    showToast('PDF 匯出失敗', 'error');
    console.error(e);
  }
  container.innerHTML = '';
  container.style.left = '-9999px';
}

